#include <cstdio>

struct MyTime {
    int h, m, s, ms;
};

// 1. 값 반환 방식: 결과 객체를 직접 리턴함
MyTime addTime(MyTime t1, MyTime t2) {
    MyTime res;
    int carry = 0;

    // 밀리초 계산 및 올림 발생 처리
    res.ms = (t1.ms + t2.ms) % 1000;
    carry = (t1.ms + t2.ms) / 1000;

    // 초 계산
    res.s = (t1.s + t2.s + carry) % 60;
    carry = (t1.s + t2.s + carry) / 60;

    // 분 계산
    res.m = (t1.m + t2.m + carry) % 60;
    carry = (t1.m + t2.m + carry) / 60;

    // 시 계산
    res.h = t1.h + t2.h + carry;

    return res;
}

int main() {
    MyTime t1 = {1, 40, 30, 700};
    MyTime t2 = {0, 30, 40, 500};

    // 함수가 반환한 값을 변수에 대입 (복사 발생)
    MyTime result = addTime(t1, t2);

    printf("[값 반환 방식 결과]\n");
    printf("%02d:%02d:%02d:%03d\n", result.h, result.m, result.s, result.ms);

    return 0;
}

#include <cstdio>

struct MyTime {
    int h, m, s, ms;
};

// 2. 참조 전달 방식: 세 번째 인자인 t3를 직접 수정함
void addTime(MyTime t1, MyTime t2, MyTime& t3) {
    int carry = 0;

    t3.ms = (t1.ms + t2.ms) % 1000;
    carry = (t1.ms + t2.ms) / 1000;

    t3.s = (t1.s + t2.s + carry) % 60;
    carry = (t1.s + t2.s + carry) / 60;

    t3.m = (t1.m + t2.m + carry) % 60;
    carry = (t1.m + t2.m + carry) / 60;

    t3.h = t1.h + t2.h + carry;
}

int main() {
    MyTime t1 = {1, 40, 30, 700};
    MyTime t2 = {0, 30, 40, 500};
    MyTime result; // 결과를 담을 공간을 먼저 만들어야 함

    // 변수의 이름(참조)을 그대로 전달
    addTime(t1, t2, result);

    printf("[참조 전달 방식 결과]\n");
    printf("%02d:%02d:%02d:%03d\n", result.h, result.m, result.s, result.ms);

    return 0;
}

#include <cstdio>

struct MyTime {
    int h, m, s, ms;
};

// 3. 포인터 전달 방식: 주소값을 타고 가서 외부 메모리에 값을 기록함
void addTime(MyTime t1, MyTime t2, MyTime* pt) {
    if (pt == nullptr) return; // 안전을 위한 디버깅용 예외 처리

    int carry = 0;

    // 포인터를 사용할 때는 -> 연산자로 멤버에 접근함
    pt->ms = (t1.ms + t2.ms) % 1000;
    carry = (t1.ms + t2.ms) / 1000;

    pt->s = (t1.s + t2.s + carry) % 60;
    carry = (t1.s + t2.s + carry) / 60;

    pt->m = (t1.m + t2.m + carry) % 60;
    carry = (t1.m + t2.m + carry) / 60;

    pt->h = t1.h + t2.h + carry;
}

int main() {
    MyTime t1 = {1, 40, 30, 700};
    MyTime t2 = {0, 30, 40, 500};
    MyTime result;

    // 변수의 주소(&)를 추출하여 전달
    addTime(t1, t2, &result);

    printf("[포인터 전달 방식 결과]\n");
    printf("%02d:%02d:%02d:%03d\n", result.h, result.m, result.s, result.ms);

    return 0;
}
