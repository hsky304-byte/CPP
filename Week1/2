#include <cstdio>

struct MyTime {
    int h, m, s, ms;
};

// MyTime 객체를 형식에 맞춰 출력
void printTime(MyTime duration) {
    // %02d: 2자리로 출력하되 빈 곳은 0으로 채움
    // %03d: 3자리로 출력하되 빈 곳은 0으로 채움
    std::printf("%02d:%02d:%02d:%03d\n", 
                duration.h, duration.m, duration.s, duration.ms);
}

int main() {
    MyTime example = {1, 2, 34, 567};
    printTime(example); // 결과: 01:02:34:567
    return 0;
}
