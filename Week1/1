#include <iostream>

struct MyTime {
    int h, m, s, ms;
};

// 초(sec)를 MyTime 구조체로 변환하여 반환
MyTime convertTime(double duration) {
    MyTime t;
    // 계산 편의를 위해 전체를 밀리초(ms) 단위로 변환
    long total_ms = (long)(duration * 1000);

    t.h = total_ms / 3600000;         // 1시간 = 3,600,000ms
    total_ms %= 3600000;
    
    t.m = total_ms / 60000;           // 1분 = 60,000ms
    total_ms %= 60000;
    
    t.s = total_ms / 1000;            // 1초 = 1,000ms
    t.ms = total_ms % 1000;           // 남은 값은 밀리초
    
    return t;
}

int main() {
    double input = 3754.567; // 예시: 1시간 2분 34초 567ms
    MyTime result = convertTime(input);
    
    std::printf("변환 결과: %d시 %d분 %d초 %dms\n", result.h, result.m, result.s, result.ms);
    return 0;
}
